; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="dx"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.png"

[debug]

gdscript/warnings/directory_rules={
"res://addons": 0,
"res://addons/dx": 1
}

[editor_plugins]

enabled=PackedStringArray("res://addons/dx/plugin.cfg", "res://addons/gut/plugin.cfg")

[godot_hub]

godot_hub/create_time="2026-02-24 21:48:39.464170"
godot_hub/engine/version="4.6.1-stable"
godot_hub/open_time="2026-02-24 21:48:39.464170"

[rendering]

textures/vram_compression/import_etc2_astc=true
